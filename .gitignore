# 编译生成的目录（ESP-IDF 编译产物）
/build/
/bootloader/build/
/partition_table/
# 编译配置文件（自动生成，不提交）
/sdkconfig
/sdkconfig.old
/sdkconfig.defaults
cmake-build-debug/
cmake-build-release/
# 日志文件与备份文件
*.log
*.bak
# Python 缓存文件（自动化测试脚本相关）
__pycache__/
*.pyc
*.pyo
# 编辑器配置文件（个人配置，不共享）
.vscode/
.idea/
*.swp
*.swo
# 压缩包（避免重复提交，仅手动归档）
*.zip
*.rar
*.gz
# 系统冗余文件
.DS_Store  # Mac 系统文件
Thumbs.db  # Windows 系统文件